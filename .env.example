# Copy to .env and fill in for production

APP_ENV=production
APP_URL=https://your-domain.com
SECRET_KEY=generate-a-long-random-string
HOST=0.0.0.0
PORT=8765

# Freemium
FREE_DAILY_CHECKS=20
FREE_DAILY_CONVERTS=3
IP_FREE_DAILY_CHECKS=40
IP_FREE_DAILY_CONVERTS=6
CONVERT_CREDIT_COST=1
CREDIT_PACK_STARTER=10
CREDIT_PACK_PRO=50

# Stripe (optional — app works free without these)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Engine
REMBG_MODEL=u2net_human_seg
USE_MEDIAPIPE=true
MAX_UPLOAD_MB=25
JOB_TTL_SECONDS=3600
